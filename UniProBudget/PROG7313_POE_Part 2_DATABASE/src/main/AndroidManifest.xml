<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera and Storage Permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Camera feature (not required, app works without it) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UniProBudget"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="31">

        <!-- FileProvider for camera photos -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Login Activity as LAUNCHER -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register Activity -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main Menu Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Expense Tracking Activity -->
        <activity
            android:name=".ExpenseTrackingActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Expense List Activity -->
        <activity
            android:name=".ExpensesListActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>


        <!-- Categories & Goals Activity -->
        <activity
            android:name=".CategoriesGoalsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Reports Dashboard Activity -->
        <activity
            android:name=".ReportsDashboardActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>